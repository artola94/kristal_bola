# Kristal Bola - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED
# =============================================================================

# xAI API Key (get yours at https://console.x.ai)
XAI_API_KEY=your-api-key-here

# =============================================================================
# OPTIONAL - Polling Configuration
# =============================================================================

# How often to poll for new data (in seconds)
# Default: 300 (5 minutes)
# KRISTAL_POLL_INTERVAL=300

# Time window to analyze (in minutes)
# Default: 15
# KRISTAL_WINDOW_MINUTES=15

# Number of retry attempts if a request fails
# Default: 3
# KRISTAL_MAX_RETRIES=3

# Delay between retries (in seconds)
# Default: 30
# KRISTAL_RETRY_DELAY=30

# =============================================================================
# OPTIONAL - MongoDB Configuration (for data persistence)
# =============================================================================

# MongoDB connection URI
# Example: mongodb://localhost:27017
# Example: mongodb+srv://user:pass@cluster.mongodb.net
# KRISTAL_MONGODB_URI=

# Database name
# Default: kristal_bola
# KRISTAL_MONGODB_DB=kristal_bola

# Collection name
# Default: sentiment_polls
# KRISTAL_MONGODB_COLLECTION=sentiment_polls

# =============================================================================
# OPTIONAL - Data Export Configuration
# =============================================================================

# Export format: csv or parquet
# Default: csv
# KRISTAL_EXPORT_FORMAT=csv

# Directory for exported data files
# Default: ./data
# KRISTAL_EXPORT_DIR=./data
